    "@mui/system": "^9.0.1",
    "@next/mdx": "^16.2.7",
    "next": "^16.2.7",
    "next-auth": "^4.24.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "web-vitals": "^5.3.0"
